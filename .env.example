# Required only for live SEC requests. Use a monitored contact address.
MARKETWITNESS_SEC_USER_AGENT="MarketWitness contact@example.com"

# Directory containing HTML reports generated by `make demo` for dashboard links.
MARKETWITNESS_GENERATED_REPORTS="build/demo"

# Public catalog of optional paid sources; it never contains credentials or purchased rows.
MARKETWITNESS_LICENSED_EXTENSIONS="data/samples/licensed_extensions.csv"

# Optional paid/authorized extension only; not required for Open Edition.
# Keep real Alpha Vantage keys outside Git.
MARKETWITNESS_ALPHA_VANTAGE_API_KEY="replace-with-private-key"

# Optional free key for live Japan FSA EDINET offering-document monitoring.
# Register at https://api.edinet-fsa.go.jp/api/auth/index.aspx?mode=1
MARKETWITNESS_EDINET_API_KEY="replace-with-private-key"
